{
  "name": "@travel/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:prod": "tsx prisma/seed.prod.ts",
    "db:studio": "prisma studio",
    "shell": "tsx --tsconfig tsconfig.json src/repl.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.17.0",
    "@sentry/node": "^10.60.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@travel/shared": "*",
    "bcrypt": "^5.1.0",
    "cloudinary": "^2.4.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.19.0",
    "firebase-admin": "^13.8.0",
    "google-auth-library": "^10.6.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.0",
    "node-cron": "^3.0.0",
    "nodemailer": "^8.0.7",
    "pino": "^10.0.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^11.2.0",
    "razorpay": "^2.9.6",
    "socket.io": "^4.7.0",
    "tsx": "^4.16.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/compression": "^1.7.0",
    "@types/cookie-parser": "^1.4.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.17.0",
    "supertest": "^7.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
