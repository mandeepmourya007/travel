generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────

enum UserRole {
  TRAVELER
  ORGANIZER
  ADMIN
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  REVISION_REQUIRED
}

enum DocumentReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TripStatus {
  DRAFT
  ACTIVE
  FULL
  COMPLETED
  CANCELLED
}

enum CancellationPolicy {
  FLEXIBLE
  MODERATE
  STRICT
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  COMPLETED
  REFUNDED
  EXPIRED
}

enum PaymentType {
  PAYMENT
  REFUND
  ESCROW_RELEASE
}

enum PaymentStatus {
  INITIATED
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  IN_APP
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  REFUND_PROCESSED
  TRIP_REMINDER
  REVIEW_REQUEST
  CHAT_MESSAGE
  ORGANIZER_APPROVED
  ORGANIZER_REJECTED
  TRIP_REQUEST_RECEIVED
  TRIP_REQUEST_APPROVED
  TRIP_REQUEST_REJECTED
  TRIP_REQUEST_EXPIRED
  ADMIN_SUPPORT_MESSAGE
  SYSTEM_ALERT
  TRIP_TYPE_REQUEST_APPROVED
  TRIP_TYPE_REQUEST_REJECTED
  DOCUMENT_REUPLOAD_REQUIRED
  WALLET_CREDIT_EXPIRING
}

enum VerificationCodeType {
  EMAIL_VERIFY
  PHONE_OTP
  EMAIL_OTP
  PASSWORD_RESET
}

enum BookingMode {
  INSTANT
  REQUEST_BASED
}

enum TripRequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED
}

enum TransferPointType {
  PICKUP
  DROP
}

enum ConversationType {
  TRIP_CHAT
  ADMIN_SUPPORT
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
  CLOSED
}

enum TripTypeRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SeatCellType {
  SEAT
  DRIVER
  EMPTY
  BLOCKED
}

enum SeatStatus {
  AVAILABLE
  HELD
  BOOKED
  BLOCKED
}

enum WalletTransactionType {
  REFUND
  CASHBACK
  BOOKING_DEDUCTION
  ADMIN_CREDIT
  ADMIN_DEBIT
  PROMOTIONAL_CREDIT
  EXPIRY
}

// ─── Models (15 MVP Tables) ──────────────────────────────

model User {
  id              String    @id @default(cuid())
  name            String
  email           String?   @unique
  phone           String?   @unique
  passwordHash    String?
  googleId        String?   @unique
  role            UserRole  @default(TRAVELER)
  avatarUrl       String?
  aadhaarVerified Boolean   @default(false)
  phoneVerified   Boolean   @default(false)
  emailVerified   Boolean   @default(false)

  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  organizerProfile  OrganizerProfile?
  bookings          Booking[]
  reviews           Review[]
  sentMessages      Message[]          @relation("sender")
  conversations     Conversation[]     @relation("traveler")
  refreshTokens     RefreshToken[]
  verificationCodes VerificationCode[]
  notifications     Notification[]
  cancelledBookings Booking[]          @relation("canceller")
  tripRequests      TripRequest[]
  tripEdits         TripEditHistory[]
  wallet            Wallet?

  @@index([email])
  @@index([role])
  @@index([isDeleted])
}

model OrganizerProfile {
  id                  String             @id @default(cuid())
  userId              String             @unique
  user                User               @relation(fields: [userId], references: [id])
  businessName        String
  slug                String             @unique
  description         String?
  verificationStatus  VerificationStatus @default(PENDING)
  documents           Json?
  rating              Float              @default(0)
  totalReviews        Int                @default(0)
  totalTripsCompleted Int                @default(0)
  bankAccountLinked   Boolean            @default(false)
  commissionRate      Float              @default(10.0)
  razorpayAccountId   String?

  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  trips             Trip[]
  conversations     Conversation[] @relation("organizer")
  tripTypeRequests  TripTypeRequest[]
  documentReviews   DocumentReview[]
  reviewComments    DocumentReviewComment[]

  @@index([verificationStatus])
  @@index([isDeleted])
}

model DocumentReview {
  id          String               @id @default(cuid())
  organizerId String
  organizer   OrganizerProfile     @relation(fields: [organizerId], references: [id])
  docType     String               // "aadhaarFront" | "aadhaarBack" | "panCard"
  status      DocumentReviewStatus @default(PENDING)
  currentUrl  String?
  reviewedAt  DateTime?
  reviewedBy  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizerId, docType])
  @@index([organizerId])
  @@index([status])
}

model DocumentReviewComment {
  id            String           @id @default(cuid())
  organizerId   String
  organizer     OrganizerProfile @relation(fields: [organizerId], references: [id])
  authorId      String
  authorRole    String           // "ADMIN" | "ORGANIZER"
  docType       String?
  comment       String
  attachmentUrl String?

  createdAt DateTime @default(now())

  @@index([organizerId, createdAt])
}

model Destination {
  id        String  @id @default(cuid())
  name      String
  slug      String  @unique
  state     String
  photoUrl    String?
  description String?
  tripCount   Int     @default(0)
  isPopular   Boolean @default(false)

  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  trips Trip[]

  @@index([isPopular, tripCount])
  @@index([isDeleted])
}

model Trip {
  id                 String             @id @default(cuid())
  organizerId        String
  organizer          OrganizerProfile   @relation(fields: [organizerId], references: [id])
  destinationId      String
  destination        Destination        @relation(fields: [destinationId], references: [id])
  title              String
  slug               String             @unique
  tripType           String
  description        String
  itinerary          Json
  startDate          DateTime
  endDate            DateTime
  bookingDeadline    DateTime?
  pricePerPerson     Int
  earlyBirdPrice     Int?
  earlyBirdDeadline  DateTime?
  minGroupSize       Int
  maxGroupSize       Int
  currentBookings    Int                @default(0)
  version            Int                @default(0)
  inclusions         Json
  exclusions         Json               @default("[]")
  cancellationPolicy CancellationPolicy @default(FLEXIBLE)
  photos             String[]
  itineraryDocUrl    String?
  status             TripStatus         @default(DRAFT)
  bookingMode        BookingMode        @default(INSTANT)
  acceptingBookings  Boolean            @default(true)
  seatSelectionEnabled Boolean           @default(false)

  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  bookings      Booking[]
  reviews       Review[]
  conversations Conversation[]
  tripRequests  TripRequest[]
  editHistory      TripEditHistory[]
  transferPoints   TripTransferPoint[]
  vehicles         TripVehicle[]

  @@index([destinationId, startDate, status])
  @@index([slug])
  @@index([organizerId, status])
  @@index([status, startDate])
  @@index([isDeleted, status])
  @@index([isDeleted, status, startDate])
  @@index([isDeleted, status, pricePerPerson])
  @@index([isDeleted, status, currentBookings])
  @@index([isDeleted, status, tripType])  // tripType filtered in search/countByType queries
  @@index([status, endDate])             // findTripsToComplete filters on status + endDate
}

model Booking {
  id             String        @id @default(cuid())
  bookingRef     String        @unique
  tripId         String
  trip           Trip          @relation(fields: [tripId], references: [id])
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  numTravelers   Int           @default(1)
  totalAmount    Int
  walletAmount   Int           @default(0)
  tripProtection Boolean       @default(false)
  bookingStatus  BookingStatus @default(PENDING_PAYMENT)
  expiresAt      DateTime?

  cancellationReason String?
  cancelledAt        DateTime?
  cancelledById      String?
  cancelledBy        User?     @relation("canceller", fields: [cancelledById], references: [id])

  pickupPointId String?
  pickupPoint   TripTransferPoint? @relation("pickupPoint", fields: [pickupPointId], references: [id])
  dropPointId   String?
  dropPoint     TripTransferPoint? @relation("dropPoint", fields: [dropPointId], references: [id])

  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Set when the trip-reminder notification has been sent for this booking.
  // Prevents the cron from re-firing on each run.
  tripReminderSentAt DateTime?

  travelerDetails     TravelerDetail[]
  paymentTransactions PaymentTransaction[]
  vehicleSeats        VehicleSeat[]
  review              Review?
  tripRequest         TripRequest?

  @@index([tripId, bookingStatus])
  @@index([userId, bookingStatus])
  @@index([bookingRef])
  @@index([bookingStatus, expiresAt])
  @@index([isDeleted])
  @@index([bookingStatus, tripReminderSentAt])  // trip-reminder cron
  // Partial unique index (not expressible in Prisma DSL — see migration 20260621000001):
  // CREATE UNIQUE INDEX "Booking_active_user_trip_unique" ON "Booking" ("userId", "tripId")
  // WHERE "bookingStatus" IN ('PENDING_PAYMENT', 'CONFIRMED') AND "isDeleted" = false
  // Prevents duplicate active bookings for the same user+trip at the DB level.
}

model TripTransferPoint {
  id          String             @id @default(cuid())
  tripId      String
  trip        Trip               @relation(fields: [tripId], references: [id])
  type        TransferPointType
  label       String
  address     String?
  time        String?
  extraCharge Int                @default(0)
  sortOrder   Int                @default(0)

  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  bookingsAsPickup Booking[] @relation("pickupPoint")
  bookingsAsDrop   Booking[] @relation("dropPoint")

  @@index([tripId, type])
  @@index([isDeleted])
}

model TravelerDetail {
  id            String       @id @default(cuid())
  bookingId     String?
  booking       Booking?     @relation(fields: [bookingId], references: [id])
  tripRequestId String?
  tripRequest   TripRequest? @relation(fields: [tripRequestId], references: [id])
  name          String
  phone         String?
  age           Int?
  gender        Gender?
  isPrimary     Boolean      @default(false)
  emergencyContactName  String?
  emergencyContactPhone String?

  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  assignedSeat VehicleSeat?

  @@index([bookingId])
  @@index([tripRequestId])
  @@index([isDeleted])
}

model TripVehicle {
  id            String   @id @default(cuid())
  tripId        String
  trip          Trip     @relation(fields: [tripId], references: [id])
  label         String   @default("Main Vehicle")
  vehicleType   String
  sortOrder     Int      @default(0)

  rows          Int
  cols          Int
  aisleAfterCol Int?
  driverRow     Int      @default(0)
  driverCol     Int

  layout        Json
  photos        String[]

  isActive      Boolean  @default(true)
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  seats         VehicleSeat[]

  @@index([tripId])
  @@index([isDeleted])
}

model VehicleSeat {
  id              String      @id @default(cuid())
  tripVehicleId   String
  tripVehicle     TripVehicle @relation(fields: [tripVehicleId], references: [id])

  row             Int
  col             Int
  seatLabel       String
  seatNumber      Int
  status          SeatStatus  @default(AVAILABLE)

  bookingId       String?
  booking         Booking?    @relation(fields: [bookingId], references: [id])
  travelerDetailId String?    @unique
  travelerDetail  TravelerDetail? @relation(fields: [travelerDetailId], references: [id])

  heldAt          DateTime?
  heldUntil       DateTime?
  heldByUserId    String?

  isActive        Boolean  @default(true)
  isDeleted       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  @@unique([tripVehicleId, row, col])
  @@unique([tripVehicleId, seatNumber])
  @@index([tripVehicleId, status])
  @@index([bookingId])
  @@index([status, heldUntil])
  @@index([isDeleted])
}

model PaymentTransaction {
  id                  String        @id @default(cuid())
  bookingId           String
  booking             Booking       @relation(fields: [bookingId], references: [id])
  type                PaymentType
  amount              Int
  currency            String        @default("INR")
  razorpayOrderId     String?
  razorpayPaymentId   String?
  razorpayRefundId    String?
  razorpayTransferId  String?
  status              PaymentStatus @default(INITIATED)
  failureReason       String?
  metadata            Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
  @@index([razorpayOrderId])
  @@index([razorpayPaymentId])
  @@index([status])
  @@index([status, type])
}

model Review {
  id                 String  @id @default(cuid())
  tripId             String
  trip               Trip    @relation(fields: [tripId], references: [id])
  bookingId          String  @unique
  booking            Booking @relation(fields: [bookingId], references: [id])
  userId             String
  user               User    @relation(fields: [userId], references: [id])
  overallRating      Int
  organizationRating Int?
  valueRating        Int?
  safetyRating       Int?
  accuracyRating     Int?
  comment            String?
  photos             String[]
  editedAt           DateTime?
  organizerReply     String?
  organizerReplyAt   DateTime?

  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([tripId])
  @@index([userId])
  @@index([isDeleted])
}

model Conversation {
  id                 String             @id @default(cuid())
  type               ConversationType   @default(TRIP_CHAT)
  status             ConversationStatus @default(ACTIVE)
  tripId             String?
  trip               Trip?              @relation(fields: [tripId], references: [id])
  travelerId         String
  traveler           User               @relation("traveler", fields: [travelerId], references: [id])
  organizerProfileId String?
  organizerProfile   OrganizerProfile?  @relation("organizer", fields: [organizerProfileId], references: [id])
  adminId            String?
  lastMessageAt      DateTime?
  lastMessagePreview String?
  unreadCountTraveler  Int             @default(0)
  unreadCountOrganizer Int             @default(0)

  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  messages Message[]

  @@unique([type, tripId, travelerId])
  @@index([travelerId, type])
  @@index([organizerProfileId])
  @@index([adminId])
  @@index([type, status])
  @@index([isDeleted])
  @@index([lastMessageAt])  // conversation lists sort by lastMessageAt
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderId       String
  sender         User         @relation("sender", fields: [senderId], references: [id])
  type           MessageType  @default(TEXT)
  content        String
  /// Client-generated idempotency key — a retried send (socket ack timeout →
  /// REST fallback) maps onto the same row instead of creating a duplicate.
  /// Nullable: system messages and older clients don't send one.
  clientMsgId    String?
  originalContent String?
  isFlagged      Boolean      @default(false)
  readAt         DateTime?
  fileUrl        String?
  fileName       String?
  fileSize       Int?
  reactions      Json         @default("[]")
  replyToId      String?
  replyTo        Message?     @relation("replies", fields: [replyToId], references: [id])
  replies        Message[]    @relation("replies")

  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Scoped to sender so one user's key can never collide with (or block) another's.
  // Postgres treats NULLs as distinct, so legacy/system rows are unaffected.
  @@unique([conversationId, senderId, clientMsgId])
  @@index([conversationId, createdAt])
  @@index([conversationId, readAt])
  @@index([isFlagged])
  @@index([isDeleted])
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  tokenHash  String    @unique
  familyId   String?
  deviceInfo String?
  ipAddress  String?
  expiresAt  DateTime
  revokedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@index([familyId])
}

model VerificationCode {
  id         String               @id @default(cuid())
  userId     String?
  user       User?                @relation(fields: [userId], references: [id])
  type       VerificationCodeType
  identifier String
  codeHash   String
  expiresAt  DateTime
  usedAt     DateTime?
  attempts   Int                  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier, type])
  @@index([expiresAt])
}

model Notification {
  id            String              @id @default(cuid())
  userId        String
  user          User                @relation(fields: [userId], references: [id])
  channel       NotificationChannel
  type          NotificationType
  title         String
  body          String
  data          Json?
  sentAt        DateTime?
  readAt        DateTime?
  failureReason String?

  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId, readAt])
  @@index([channel, sentAt])
  @@index([isDeleted])
}

model WebhookEvent {
  id                String    @id @default(cuid())

  // ── Source Identification ──────────────────────────
  source            String
  externalEventId   String
  eventType         String

  // ── Internal Reference (Polymorphic) ───────────────
  referenceModel    String?
  referenceId       String?

  // ── External Reference ─────────────────────────────
  externalId        String?

  // ── Payload Storage ────────────────────────────────
  headers           Json?
  payload           Json
  response          Json?

  // ── Processing Status ──────────────────────────────
  status            String    @default("RECEIVED")
  mode              String    @default("live")
  failureReason     String?
  attempts          Int       @default(1)
  processedAt       DateTime?

  // ── Timestamps (NO soft-delete — immutable audit trail) ──
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // ── Indexes ────────────────────────────────────────
  @@unique([source, externalEventId])
  @@index([source, eventType])
  @@index([referenceModel, referenceId])
  @@index([externalId])
  @@index([status])
  @@index([createdAt])
  @@index([mode])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  balance   Int      @default(0)
  currency  String   @default("INR")

  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  transactions WalletTransaction[]

  @@index([isDeleted])
  // IMPORTANT: After migration, run raw SQL to add CHECK constraint:
  // ALTER TABLE "Wallet" ADD CONSTRAINT wallet_balance_non_negative CHECK (balance >= 0);
}

model WalletTransaction {
  id             String                @id @default(cuid())
  walletId       String
  wallet         Wallet                @relation(fields: [walletId], references: [id])
  amount         Int
  type           WalletTransactionType
  referenceModel String?
  referenceId    String?
  description    String
  balanceBefore  Int
  balanceAfter   Int

  // Nullable — set only on expirable credits (cashback, promotional credit).
  // Refunds and admin credits leave these null.
  expiresAt             DateTime?
  expiryReminderSentAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, referenceModel, referenceId])
  @@index([walletId, createdAt])
  @@index([referenceModel, referenceId])
  @@index([type])
  @@index([expiresAt])  // wallet expiry sweep cron
}

model TripCategory {
  id        String   @id @default(cuid())
  value     String   @unique
  label     String
  icon      String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model TripTypeRequest {
  id            String                @id @default(cuid())
  organizerId   String
  organizer     OrganizerProfile      @relation(fields: [organizerId], references: [id])
  suggestedName String
  reason        String
  status        TripTypeRequestStatus @default(PENDING)
  adminNote     String?
  reviewedAt    DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([status])
  @@index([organizerId])
}

model TripEditHistory {
  id            String   @id @default(cuid())
  tripId        String
  trip          Trip     @relation(fields: [tripId], references: [id])
  editedById    String
  editedBy      User     @relation(fields: [editedById], references: [id])
  snapshot      Json
  changedFields String[]
  editNote      String?

  createdAt     DateTime @default(now())

  @@index([tripId, createdAt])
  @@index([editedById])
}

model TripRequest {
  id                String            @id @default(cuid())
  tripId            String
  trip              Trip              @relation(fields: [tripId], references: [id])
  userId            String
  user              User              @relation(fields: [userId], references: [id])
  numTravelers      Int               @default(1)
  message           String?
  travelerDetails   TravelerDetail[]
  status            TripRequestStatus @default(PENDING)
  respondedAt       DateTime?
  responseNote      String?
  approvalExpiresAt DateTime?
  bookingId         String?           @unique
  booking           Booking?          @relation(fields: [bookingId], references: [id])

  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([tripId, userId])
  @@index([tripId, status])
  @@index([userId, status])
  @@index([status, approvalExpiresAt])
  @@index([isDeleted])
}
