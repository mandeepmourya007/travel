# ─── Production Environment Template ─────────────────
# Copy to .env.prod and fill in values.
# The deploy script (scripts/deploy-prod.sh) auto-generates this
# with strong random secrets on first run.

# ─── Server ──────────────────────────────────────────
SERVER_IP=YOUR_SERVER_IP
SERVER_NAME=_
WEB_PORT=3000
# Set DOMAIN + ACME_EMAIL to enable HTTPS:
# DOMAIN=safarnama.in
# ACME_EMAIL=you@email.com

# ─── Database ────────────────────────────────────────
POSTGRES_USER=travel_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=travel_prod

# ─── Redis ───────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── Auth ────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_LONG_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_MIN_32_CHARS_LONG_SECRET
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Razorpay ───────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ─── Cloudinary ─────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── SMTP (Email OTP / Notifications) ─────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@safarnama.in

# ─── MSG91 (OTP SMS) ────────────────────────────────
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_TEMPLATE_ID=your-msg91-template-id

# ─── Firebase (Phone Auth — optional) ─────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
NEXT_PUBLIC_PHONE_AUTH_STRATEGY=backend

# ─── Client URLs ────────────────────────────────────
CLIENT_URL=http://YOUR_SERVER_IP
NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP/api/v1
NEXT_PUBLIC_SOCKET_URL=http://YOUR_SERVER_IP
NEXT_PUBLIC_APP_NAME=Safarnama
NEXT_PUBLIC_SITE_URL=https://YOUR_DOMAIN
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# ─── Logging ────────────────────────────────────────
LOG_LEVEL=info
NEXT_PUBLIC_LOG_LEVEL=warn
