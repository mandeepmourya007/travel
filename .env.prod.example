# ════════════════════════════════════════════════════
# PRODUCTION ENVIRONMENT TEMPLATE (Docker / VPS)
# Copy to .env.prod and fill in your values:
#   cp .env.prod.example .env.prod
# ════════════════════════════════════════════════════

# ════════════════════════════════════════════════════
# CORE
# ════════════════════════════════════════════════════
NODE_ENV=production
PORT=4000
WEB_PORT=3000
LOG_LEVEL=info
NEXT_PUBLIC_LOG_LEVEL=warn

# ════════════════════════════════════════════════════
# DOMAIN & NETWORKING
# ════════════════════════════════════════════════════
SERVER_NAME=your-domain.com
DOMAIN=your-domain.com
ACME_EMAIL=you@email.com
CLIENT_URL=https://your-domain.com
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
NEXT_PUBLIC_API_URL=https://your-domain.com/api/v1
NEXT_PUBLIC_SOCKET_URL=https://your-domain.com
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ════════════════════════════════════════════════════
# DATABASE (PostgreSQL)
# ════════════════════════════════════════════════════
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql://travel:CHANGE_ME_STRONG_PASSWORD@postgres:5432/travel?schema=public
DIRECT_URL=postgresql://travel:CHANGE_ME_STRONG_PASSWORD@postgres:5432/travel?schema=public

# ════════════════════════════════════════════════════
# AUTH (JWT & Google OAuth)
# ════════════════════════════════════════════════════
# Generate a strong secret: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_LONG_SECRET
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Required by Next.js frontend for Google sign-in button
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# ════════════════════════════════════════════════════
# FIREBASE (Phone Auth)
# ════════════════════════════════════════════════════
# Server SDK — used by API only
PHONE_AUTH_STRATEGY=firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Client SDK — used by Next.js frontend only
NEXT_PUBLIC_PHONE_AUTH_STRATEGY=firebase
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id

# ════════════════════════════════════════════════════
# REDIS (Upstash)
# ════════════════════════════════════════════════════
# Format: rediss://default:<password>@<host>.upstash.io:6380
REDIS_URL=rediss://default:your-upstash-password@your-url.upstash.io:6380

# ════════════════════════════════════════════════════
# EMAIL (SMTP)
# ════════════════════════════════════════════════════
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=Safarnama <noreply@safarnama.in>

# ════════════════════════════════════════════════════
# SMS OTP (MSG91 — alternative to Firebase phone auth)
# ════════════════════════════════════════════════════
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_TEMPLATE_ID=your-msg91-template-id

# ════════════════════════════════════════════════════
# PAYMENTS (Razorpay)
# ════════════════════════════════════════════════════
# Use live keys (rzp_live_*) in production
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
# Set this to the webhook secret from Razorpay dashboard — must NOT equal KEY_SECRET
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ════════════════════════════════════════════════════
# MEDIA (Cloudinary)
# ════════════════════════════════════════════════════
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ════════════════════════════════════════════════════
# MONITORING (Sentry)
# ════════════════════════════════════════════════════
SENTRY_DSN=your-api-sentry-dsn
NEXT_PUBLIC_SENTRY_DSN=your-web-sentry-dsn

# ════════════════════════════════════════════════════
# LEGAL (frontend display only)
# ════════════════════════════════════════════════════
NEXT_PUBLIC_CONTACT_EMAIL=support@safarnama.in
NEXT_PUBLIC_GRIEVANCE_EMAIL=grievance@safarnama.in
NEXT_PUBLIC_GRIEVANCE_OFFICER_NAME=Your Name Here
