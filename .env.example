# ════════════════════════════════════════════════════
# LOCAL DEVELOPMENT TEMPLATE
# Copy to .env and fill in your values:
#   cp .env.example .env
# ════════════════════════════════════════════════════

# ════════════════════════════════════════════════════
# CORE
# ════════════════════════════════════════════════════
NODE_ENV=development
PORT=4001
LOG_LEVEL=debug
NEXT_PUBLIC_LOG_LEVEL=debug

# ════════════════════════════════════════════════════
# DOMAIN & NETWORKING
# ════════════════════════════════════════════════════
CLIENT_URL=http://localhost:3000
ALLOWED_ORIGINS=
NEXT_PUBLIC_API_URL=http://localhost:4001/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:4001
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Server-side only — used for SSR/route handlers inside Docker network
API_URL_INTERNAL=http://localhost:4001/api/v1

# ════════════════════════════════════════════════════
# DATABASE (PostgreSQL)
# ════════════════════════════════════════════════════
DATABASE_URL=postgresql://user:password@localhost:5432/travel_db?schema=public
# Direct connection for Prisma CLI (same as DATABASE_URL in local dev)
DIRECT_URL=postgresql://user:password@localhost:5432/travel_db?schema=public

# ════════════════════════════════════════════════════
# AUTH (JWT & Google OAuth)
# ════════════════════════════════════════════════════
# Generate a strong secret: openssl rand -base64 48
JWT_SECRET=your-jwt-secret-min-32-chars-long-here
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Required by Next.js frontend for Google sign-in button
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# ════════════════════════════════════════════════════
# FIREBASE (Phone Auth)
# ════════════════════════════════════════════════════
# Server SDK — used by API only
# Strategy: "backend" (MSG91/SMTP OTP) or "firebase"
PHONE_AUTH_STRATEGY=backend
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
# Client SDK — used by Next.js frontend only
NEXT_PUBLIC_PHONE_AUTH_STRATEGY=backend
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id

# ════════════════════════════════════════════════════
# REDIS
# ════════════════════════════════════════════════════
REDIS_URL=redis://:password@localhost:6379

# ════════════════════════════════════════════════════
# EMAIL — Resend is preferred; SMTP is the fallback if RESEND_API_KEY is unset
# ════════════════════════════════════════════════════
RESEND_API_KEY=re_xxx
RESEND_FROM=Safarnama <noreply@safarnama.store>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Safarnama <your-email@gmail.com>
# Reply-To on every outgoing email — must be a real, monitored inbox on your sending
# domain (not a free-mail address); improves deliverability/inbox placement.
SUPPORT_EMAIL=support@safarnama.store

# ════════════════════════════════════════════════════
# SMS OTP (MSG91 — alternative to Firebase phone auth)
# ════════════════════════════════════════════════════
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_TEMPLATE_ID=your-msg91-template-id

# ════════════════════════════════════════════════════
# WHATSAPP (MSG91 — transactional + OTP + broadcasts)
# MSG91_WA_BUSINESS_NUMBER: exact value shown on MSG91 dashboard → WhatsApp →
# your number's row. Already includes its own country code — copy verbatim,
# do NOT strip/re-add a country code (e.g. Meta's sandbox test number is a
# US-format "1555XXXXXXX"; a real number would look like "91XXXXXXXXXX").
# MSG91_WA_OTP_PREFER=true  → send OTP via WhatsApp instead of SMS
# Template names must be pre-approved in Meta Business Manager
# ════════════════════════════════════════════════════
MSG91_WA_BUSINESS_NUMBER=your-msg91-whatsapp-integrated-number
MSG91_WA_OTP_TEMPLATE=your-whatsapp-otp-template-name
MSG91_WA_OTP_PREFER=false
MSG91_WA_TPL_BOOKING_CONFIRMED=booking_confirmed
MSG91_WA_TPL_BOOKING_CANCELLED=booking_cancelled
MSG91_WA_TPL_PAYMENT_RECEIVED=payment_received
MSG91_WA_TPL_PAYMENT_FAILED=payment_failed
MSG91_WA_TPL_REFUND_PROCESSED=refund_processed
MSG91_WA_TPL_TRIP_REMINDER=trip_reminder
MSG91_WA_TPL_ORGANIZER_APPROVED=organizer_approved
MSG91_WA_TPL_ORGANIZER_REJECTED=organizer_rejected
MSG91_WA_TPL_TRIP_REQUEST_APPROVED=trip_request_approved
MSG91_WA_TPL_DOCUMENT_REUPLOAD_REQUIRED=document_reupload_required
MSG91_WA_TPL_WALLET_CREDIT_EXPIRING=wallet_credit_expiring
MSG91_WA_TPL_TRIP_TYPE_REQUEST_APPROVED=trip_type_request_approved

# ════════════════════════════════════════════════════
# PAYMENTS (Razorpay)
# ════════════════════════════════════════════════════
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ════════════════════════════════════════════════════
# PAYMENT GATEWAY SELECTION
# razorpay (default) | cashfree
# ════════════════════════════════════════════════════
PAYMENT_GATEWAY=razorpay

# ════════════════════════════════════════════════════
# CASHFREE (full integration — get from merchant.cashfree.com)
# CASHFREE_ENV: sandbox | production
# ════════════════════════════════════════════════════
CASHFREE_APP_ID=your-cashfree-app-id
CASHFREE_SECRET_KEY=your-cashfree-secret-key
CASHFREE_WEBHOOK_SECRET=your-cashfree-webhook-secret
CASHFREE_ENV=sandbox
# Client SDK mode — must match CASHFREE_ENV above
NEXT_PUBLIC_CASHFREE_ENV=sandbox
# Enables Cashfree Easy Split order_splits[]/vendor-transfer testing in sandbox, where
# vendor bank-account verification never completes so splits are normally skipped outside
# production. Moves no real money — only relaxes the split-attachment gate in
# booking.service.ts. Leave false/unset unless you're specifically testing the
# deposit/balance payout flow against Cashfree's sandbox.
CASHFREE_ENABLE_SANDBOX_SPLIT=false

# ════════════════════════════════════════════════════
# MEDIA (Cloudinary)
# ════════════════════════════════════════════════════
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ════════════════════════════════════════════════════
# MONITORING (Sentry — leave blank to disable)
# ════════════════════════════════════════════════════
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.2
# Enables readable stack traces via source map upload to Sentry
SENTRY_AUTH_TOKEN=

# ════════════════════════════════════════════════════
# LEGAL (frontend display only)
# ════════════════════════════════════════════════════
# Update GRIEVANCE_OFFICER_NAME to a real person before going live (IT Rules 2021)
NEXT_PUBLIC_CONTACT_EMAIL=support@safarnama.in
NEXT_PUBLIC_GRIEVANCE_EMAIL=grievance@safarnama.in
NEXT_PUBLIC_GRIEVANCE_OFFICER_NAME=Your Name Here

# ════════════════════════════════════════════════════
# SEO — Search Console Verification
# Google: https://search.google.com/search-console → Add property → HTML tag method
# Bing:   https://www.bing.com/webmasters → Add site → Meta tag method
# Bing verification is critical — ChatGPT cites Bing-indexed content.
# Leave blank in dev; only needed in production.
# ════════════════════════════════════════════════════
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
