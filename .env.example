# ─── Core ──────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database ──────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/travel_db?schema=public

# ─── Auth ──────────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-chars-long-here
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-long
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Razorpay ─────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ─── Cloudinary ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Redis ────────────────────────────────────────
REDIS_URL=redis://:password@localhost:6379

# ─── MSG91 (OTP SMS) ─────────────────────────────
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_TEMPLATE_ID=your-msg91-template-id

# ─── SMTP (Email OTP) ───────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=TripCompare <your-email@gmail.com>

# ─── Firebase (Phone Auth — optional) ───────────
# Backend (Admin SDK — for verifying Firebase ID tokens)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
# Phone auth strategy: "backend" (MSG91) or "firebase" (Firebase client SDK)
PHONE_AUTH_STRATEGY=backend

# ─── Client ────────────────────────────────────────
WEB_PORT=3000
CLIENT_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_NAME=TripCompare
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
# Firebase Client SDK (only needed if PHONE_AUTH_STRATEGY=firebase)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
# Phone auth strategy for frontend
NEXT_PUBLIC_PHONE_AUTH_STRATEGY=backend

# ─── Logging ───────────────────────────────────────
LOG_LEVEL=debug
