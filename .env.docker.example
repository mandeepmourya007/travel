# ─── Docker Development Environment ──────────────────
# Copy this file to .env.docker and fill in your values:
#   cp .env.docker.example .env.docker
#
# Docker Compose loads this via env_file for external service credentials.
# Internal vars (DATABASE_URL, JWT secrets) are set in docker-compose.yml.

# ─── Razorpay ─────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── Google OAuth ─────────────────────────────────
# GOOGLE_CLIENT_ID (API) and NEXT_PUBLIC_GOOGLE_CLIENT_ID (Web) use the same value
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Cloudinary ───────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── MSG91 (OTP SMS) ─────────────────────────────
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# ─── SMTP (Email OTP) ───────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Firebase (Phone Auth — optional) ───────────
# Backend (Admin SDK)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Strategy: "backend" (MSG91) or "firebase"
PHONE_AUTH_STRATEGY=backend

# Frontend (Client SDK — only needed if PHONE_AUTH_STRATEGY=firebase)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_PHONE_AUTH_STRATEGY=backend

# ─── Site URL ──────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Logging ───────────────────────────────────────
NEXT_PUBLIC_LOG_LEVEL=debug

# ─── Redis ───────────────────────────────────────────
# REDIS_URL is set in docker-compose.yml (points to local Redis container).
# No config needed here unless overriding.
