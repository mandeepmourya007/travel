# ════════════════════════════════════════════════════
# DOCKER DEVELOPMENT OVERRIDES
# Copy to .env.docker and fill in your values:
#   cp .env.docker.example .env.docker
#
# Docker Compose loads this via env_file for credentials
# that can't be hardcoded in docker-compose.yml.
# Core vars (DATABASE_URL, REDIS_URL, JWT_SECRET) are
# already set in docker-compose.yml — no need to repeat them here.
# ════════════════════════════════════════════════════

# ════════════════════════════════════════════════════
# AUTH (Google OAuth)
# ════════════════════════════════════════════════════
# Both API and web use the same Google Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ════════════════════════════════════════════════════
# FIREBASE (Phone Auth)
# ════════════════════════════════════════════════════
# Server SDK — used by API only
# Strategy: "backend" (MSG91/SMTP OTP) or "firebase"
PHONE_AUTH_STRATEGY=backend
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Client SDK — used by Next.js frontend only
NEXT_PUBLIC_PHONE_AUTH_STRATEGY=backend
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ════════════════════════════════════════════════════
# EMAIL (SMTP)
# ════════════════════════════════════════════════════
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ════════════════════════════════════════════════════
# SMS OTP (MSG91 — alternative to Firebase phone auth)
# ════════════════════════════════════════════════════
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# ════════════════════════════════════════════════════
# PAYMENTS (Razorpay)
# ════════════════════════════════════════════════════
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ════════════════════════════════════════════════════
# MEDIA (Cloudinary)
# ════════════════════════════════════════════════════
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ════════════════════════════════════════════════════
# FRONTEND
# ════════════════════════════════════════════════════
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_LOG_LEVEL=debug
