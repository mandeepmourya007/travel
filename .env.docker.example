# ─── Docker Development Environment ──────────────────
# Copy this file to .env.docker and fill in your values:
#   cp .env.docker.example .env.docker
#
# Docker Compose loads this via env_file for external service credentials.
# Internal vars (DATABASE_URL, JWT secrets) are set in docker-compose.yml.

# ─── Razorpay ─────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── Google OAuth ─────────────────────────────────
# GOOGLE_CLIENT_ID (API) and NEXT_PUBLIC_GOOGLE_CLIENT_ID (Web) use the same value
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Cloudinary ───────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── MSG91 (OTP SMS) ─────────────────────────────
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# ─── Redis ───────────────────────────────────────────
# REDIS_URL is set in docker-compose.yml (points to local Redis container).
# No config needed here unless overriding.
